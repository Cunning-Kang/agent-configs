{
  "_comment": "Template for Claude Code settings.json. Copy to settings.json on the local machine and fill in. Do not commit a live settings.json. The field set below mirrors the real Claude Code schema; values are placeholders for machine-specific data, model routing, permissions, env overrides, hook paths, and secrets. See README.md in this directory for the manual copy/fill workflow. All path placeholders use <...> tokens that must be replaced with values valid on the target machine before the file is used.",
  "_notes": {
    "env": "Set ANTHROPIC_AUTH_TOKEN and ANTHROPIC_BASE_URL only on the local machine; never commit filled values. The remaining keys are Claude Code feature flags and proxy/model-routing defaults.",
    "permissions": "allow runs without prompting; deny blocks outright; ask always confirms; defaultMode is the global permission policy. Patterns follow Claude Code glob/syntax (e.g. Bash(git *), Edit(~/.claude/settings*)). Adjust to match this machine's toolchain.",
    "deny": "The deny list intentionally blocks recursive removal, privilege escalation, raw network downloads, hard git history rewrites, and any access to the user's settings/hooks/credential stores. Use ~-relative forms so the patterns resolve on any machine.",
    "hooks": "Hook command paths must point at scripts under this target's hooks/ directory once they are deployed. Replace <absolute-path-to-agents-target-hooks> with the resolved directory on the target machine.",
    "statusLine": "Path to the local status line script. Copy targets/claude-code/hooks/cbm-statusline.sh (or equivalent) to a stable path on the machine and set command to its absolute location.",
    "enabledPlugins": "Plugin identifiers are <name>@<marketplace-id> as observed in the local runtime. Set each value to true or false to match this machine's plugin install set. Removing an entry does not uninstall the plugin; it only stops Claude Code from loading it.",
    "extraKnownMarketplaces": "Additional marketplace sources Claude Code should know about. source.source is 'github' (with repo) or 'git' (with url).",
    "sandbox": "Sandbox policy. Network allow/deny and filesystem allow/deny are machine-specific. Replace path roots (e.g. //tmp, //etc, ~/) with paths valid on this machine."
  },

  "env": {
    "ANTHROPIC_AUTH_TOKEN": "<auth-token-or-env-reference>",
    "ANTHROPIC_BASE_URL": "<provider-base-url>",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "Haiku",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "Opus",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "Sonnet",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },

  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(brew *)",
      "Bash(mise *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(bun *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(pytest *)",
      "Bash(jest *)",
      "Bash(vitest *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(tsc *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(which *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(env *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(whoami)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(test *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(rsync *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(workmux *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(* --help *)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf)",
      "Bash(rm -r -f *)",
      "Bash(rm -r *)",
      "Bash(rm -fr *)",
      "Bash(rm --recursive *)",
      "Bash(rm -Rf *)",
      "Bash(rm -R *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Bash(git push origin --delete *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(kill -9 *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(launchctl *)",
      "Bash(diskutil *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Edit(~/.claude/settings*)",
      "Edit(.claude/settings*)",
      "Read(**/*.log)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/credentials)",
      "Edit(~/.claude/hooks/**)",
      "Write(~/.claude/hooks/**)",
      "Bash(python *~/.claude/hooks*)",
      "Bash(python3 *~/.claude/hooks*)",
      "Bash(node *~/.claude/hooks*)",
      "Bash(bun *~/.claude/hooks*)",
      "Bash(cp *~/.claude/hooks*)",
      "Bash(mv *~/.claude/hooks*)",
      "Bash(* *~/.claude/hooks*)",
      "Bash(env *~/.claude/hooks*)",
      "Bash(rsync *~/.claude/hooks*)",
      "Bash(tar *~/.claude/hooks*)",
      "Bash(npm *~/.claude/hooks*)",
      "Bash(npx *~/.claude/hooks*)"
    ],
    "ask": [
      "Bash(git restore *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)"
    ],
    "defaultMode": "bypassPermissions"
  },

  "model": "opus",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "<absolute-path-to-agents-target-hooks>/agent-model-override-gate.py",
            "timeout": 10,
            "statusMessage": "Checking Agent model override policy"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"<absolute-path-to-agents-target-hooks>/git-push-pr-preflight.sh\"",
            "timeout": 20,
            "statusMessage": "Checking push/PR preflight requirements"
          }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "<absolute-path-to-agents-target-hooks>/cbm-code-discovery-gate",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "<absolute-path-to-agents-target-hooks>/cbm-session-reminder"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "<absolute-path-to-agents-target-hooks>/cbm-session-reminder"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "<absolute-path-to-agents-target-hooks>/cbm-session-reminder"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "<absolute-path-to-agents-target-hooks>/cbm-session-reminder"
          }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "<absolute-path-to-claude-code-statusline-script>"
  },

  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "elements-of-style@superpowers-marketplace": true,
    "skill-creator@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },

  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      }
    },
    "minimax-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/MiniMax-AI/skills.git"
      }
    }
  },

  "language": "Chinese",

  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "objects.githubusercontent.com",
        "registry.npmjs.org",
        "*.npmjs.com",
        "pypi.org",
        "files.pythonhosted.org",
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "proxy.golang.org",
        "sum.golang.org",
        "pkg.go.dev",
        "dl.google.com",
        "static.rust-lang.org",
        "mise.jdx.dev",
        "registry.mise.jdx.dev",
        "nodejs.org",
        "*.nodejs.org"
      ],
      "allowAllUnixSockets": false,
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "//tmp",
        "~/.cache",
        "~/.local"
      ],
      "denyWrite": [
        "//etc",
        "//usr",
        "//System",
        "//opt",
        "~/.ssh",
        "~/.gnupg"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "docker",
      "podman",
      "watchman",
      "brew",
      "gh"
    ]
  },

  "plansDirectory": ".claude/plans",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light-ansi",
  "teammateMode": "auto",
  "hasCompletedOnboarding": true
}
